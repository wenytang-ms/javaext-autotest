{
  "name": "vscode-autotest",
  "version": "0.1.0",
  "description": "AI-driven VSCode extension E2E testing framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "autotest": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "run:test-plan": "tsx src/cli/index.ts run"
  },
  "dependencies": {
    "@playwright/test": "^1.50.0",
    "@vscode/test-electron": "^2.4.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
